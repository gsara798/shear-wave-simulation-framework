{
  "dimension": 3,
  "scenario": "homogeneous_directional_3d",
  "seed": 1001,

  "grid": {
    "Nx": 32,
    "Ny": 24,
    "Nz": 32,
    "dx_m": 0.0005,
    "dy_m": 0.0005,
    "dz_m": 0.0005
  },

  "medium": {
    "cs_m_s": 2.0,
    "rho_kg_m3": 1000,
    "cp_mode": "reduced",
    "reduced_cp_factor": 10
  },

  "source": {
    "f0_hz": 500,
    "velocity_amplitude_m_s": 0.000001,
    "contact_radius_m": 0.001,
    "ramp_cycles": 1,
    "boundary_margin_m": 0.002,
    "target_direction_xyz": [1, 0, 0],
    "polarization_xyz": [0, 0, 1]
  },

  "time": {
    "settling_cycles": 1,
    "analysis_cycles": 2,
    "end_time_s": 0.008
  },

  "sensor": {
    "source_buffer_m": 0.002,
    "boundary_margin_m": 0.0015
  },

  "solver": {
    "pml_size_points": [8, 8, 8],
    "plot_simulation": false
  },

  "output": {
    "enabled": true,
    "directory": "outputs",
    "run_name": "cli_homogeneous_directional_3d",
    "append_timestamp": true,
    "overwrite": false,
    "save_result": true,
    "save_summary": true,
    "save_config_mat": true,
    "save_config_json": true,
    "save_time_series": false,
    "save_figures": true,
    "save_matlab_figures": true
  }
